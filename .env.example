SERVER_PORT=8080

DB_HOST=
DB_PORT=3306
DB_NAME=caddy_dashboard
DB_USER=
DB_PASSWORD=
DB_PARAMS=charset=utf8mb4&parseTime=True&loc=Local

AWS_PROFILE=default
AWS_REGIONS=us-east-1,us-west-1

JWT_SECRET=change-me
# Required at startup (min length enforced by ops; use a long random value in production).

# GIN_MODE=release
# Comma-separated list is not supported; set cors_allowed_origins in configs/config.yaml for multiple origins.

LOG_LEVEL=info
