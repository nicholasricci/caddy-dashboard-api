SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=15s
CORS_ALLOWED_ORIGINS=http://localhost:4200

DB_HOST=
DB_PORT=3306
DB_NAME=caddy_dashboard
DB_USER=
DB_PASSWORD=
DB_PARAMS=charset=utf8mb4&parseTime=True&loc=Local
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=10m
DB_CONNECT_RETRIES=10
DB_CONNECT_BACKOFF=500ms

AWS_PROFILE=default
AWS_REGIONS=us-east-1,us-west-1
# Set to true to allow starting the API with no AWS regions (SSH/HTTP-only nodes).
AWS_OPTIONAL=false

# GCP OS Config / VM Manager (optional; requires ADC on the API host). Set GCP_ENABLED=false to skip client init.
GCP_ENABLED=true
GCP_OSCONFIG_TIMEOUT=3m
GCP_ASSIGNMENT_PREFIX=caddy-dash

# Azure VM Run Command (optional; DefaultAzureCredential). Set AZURE_ENABLED=false to skip.
AZURE_ENABLED=true
AZURE_RUN_COMMAND_TIMEOUT=3m
AZURE_RUN_COMMAND_POLL=2s

# Scheduler: background task execution (cron expressions, MySQL lock for multi-replica).
# Set SCHEDULER_ENABLED=false to disable all scheduled tasks.
SCHEDULER_ENABLED=true
SCHEDULER_LOG_RETENTION_DAYS=30
SCHEDULER_GLOBAL_TIMEOUT=30m

CADDY_CACHE_TTL=2m
CADDY_SSH_TIMEOUT=2m
CADDY_SSH_IDLE_TTL=5m
CADDY_HTTP_ADMIN_TIMEOUT=60s
CADDY_HTTP_MAX_RESPONSE_BODY=33554432
CADDY_SECRET_CACHE_TTL=5m

JWT_SECRET=
JWT_ISSUER=caddy-dashboard
JWT_AUDIENCE=caddy-dashboard-api
# Required at startup (>= 32 chars, random, never use placeholders in production).

# GIN_MODE=release
# Comma-separated list is not supported; set cors_allowed_origins in configs/config.yaml for multiple origins.

LOG_LEVEL=info

# Optional: Grafana Cloud Loki log shipping via Docker Compose Alloy profile.
LOKI_ENABLED=false
LOKI_URL=
LOKI_USER=
LOKI_API_KEY=
LOKI_TENANT_ID=
LOKI_ENVIRONMENT=local
ALLOY_UI_PORT=12345
